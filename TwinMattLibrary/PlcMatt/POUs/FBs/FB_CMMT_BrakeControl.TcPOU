<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_CMMT_BrakeControl" Id="{ae919a79-0ed9-44b5-8afe-2457a08282d0}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_CMMT_BrakeControl
VAR_INPUT
    (*
        Enables control of the brake-release-request PDO bit.

        FALSE:
            The FB clears bit 0 of the output mask.
            The PLC does not request control of the brake-release bit.

        TRUE:
            The FB sets bit 0 of 60FE:02.
            The PLC controls bit 0 of 60FE:01.

        For a manual/service brake-release function, this input would
        normally be enabled only while the machine is in an authorised
        service or commissioning mode.
    *)
    i_bEnableManualBrakeControl : BOOL;


    (*
        Operator or application request to release the holding brake.

        FALSE:
            No manual release request.

        TRUE:
            Request the CMMT to release/open the holding brake.

        This input does not bypass i_bReleasePermitted.
    *)
    i_bManualBrakeRelease : BOOL;


    (*
        Application interlock permitting brake release.

        Suggested conditions for a vertical axis include:

            - Safety system permits movement
            - Axis is mechanically supported, or motor torque is established
            - Machine is in an authorised operating mode
            - No active brake-related fault
            - No conflicting stop or emergency command

        The FB only issues the release request when this input is TRUE.
    *)
    i_bReleasePermitted : BOOL;


    (*
        Raw brake status received from object 2150:05.

        Expected values:

            0 = Brake closed
            1 = Brake open
            2 = Brake opening
            3 = Brake closing
    *)
    i_udiBrakeStatusRaw : UDINT;
END_VAR


VAR_IN_OUT
    (*
        Object 60FE:01 — Digital outputs.

        Only bit 0 is modified by this FB.
        All other bits are preserved.
    *)
    io_udiDigitalOutputs : UDINT;


    (*
        Object 60FE:02 — Digital output mask.

        Only bit 0 is modified by this FB.
        All other mask bits are preserved.
    *)
    io_udiDigitalOutputsMask : UDINT;
END_VAR


VAR_OUTPUT
    (*
        TRUE when the PLC currently owns the brake-release bit and is
        actively sending a release request.
    *)
    o_bReleaseRequestActive : BOOL;


    (*
        Decoded brake status.
    *)
    o_eBrakeStatus : E_CMMT_BrakeStatus;


    (*
        Individual status outputs for simple use in application logic
        and HMI displays.
    *)
    o_bBrakeClosed  : BOOL;
    o_bBrakeOpen    : BOOL;
    o_bBrakeOpening : BOOL;
    o_bBrakeClosing : BOOL;


    (*
        TRUE while the brake is either opening or closing.
    *)
    o_bBrakeTransitioning : BOOL;


    (*
        TRUE when 2150:05 contains one of the documented values 0...3.

        FALSE means that an unexpected value was received.
    *)
    o_bBrakeStatusValid : BOOL;


    (*
        TRUE when the operator requested brake release, but an application
        interlock prevented the request from being sent.
    *)
    o_bReleaseRequestBlocked : BOOL;
END_VAR


VAR
    (*
        Final internally calculated release request.

        The EtherCAT command is only issued when all three conditions
        are TRUE.
    *)
    bReleaseRequest : BOOL;
END_VAR


VAR CONSTANT
    (*
        Bit mask for bit 0.

        This bit is used in both:

            60FE:01 Digital outputs
            60FE:02 Digital output mask
    *)
    C_UDI_BRAKE_RELEASE : UDINT := 16#00000001;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
(*
    =====================================================================
    CALCULATE THE FINAL BRAKE-RELEASE REQUEST
    =====================================================================

    The request is accepted only when:

        1. Manual brake control is enabled.
        2. A brake-release request is present.
        3. The application permits brake release.
*)
bReleaseRequest :=
    i_bEnableManualBrakeControl
    AND i_bManualBrakeRelease
    AND i_bReleasePermitted;


(*
    Indicate when the requested operation has been blocked by an
    application interlock.

    This can be displayed on the HMI to explain why pressing the
    brake-release button did not release the brake.
*)
o_bReleaseRequestBlocked :=
    i_bEnableManualBrakeControl
    AND i_bManualBrakeRelease
    AND NOT i_bReleasePermitted;


(*
    =====================================================================
    CONTROL 60FE:02 — DIGITAL OUTPUT MASK
    =====================================================================

    Setting bit 0 in the mask gives the fieldbus/PLC control over
    bit 0 of 60FE:01.

    OR is used instead of direct assignment so that any other output-mask
    bits used elsewhere in the application are not overwritten.
*)
IF i_bEnableManualBrakeControl THEN

    io_udiDigitalOutputsMask :=
        io_udiDigitalOutputsMask OR C_UDI_BRAKE_RELEASE;

ELSE

    (*
        Remove PLC control of the brake-release-request bit.

        AND NOT clears only bit 0 and preserves all other mask bits.
    *)
    io_udiDigitalOutputsMask :=
        io_udiDigitalOutputsMask AND (NOT C_UDI_BRAKE_RELEASE);

END_IF


(*
    =====================================================================
    CONTROL 60FE:01 — BRAKE RELEASE REQUEST
    =====================================================================

    Bit 0 = 1:
        Request the holding brake to open/release.

    Bit 0 = 0:
        Remove the manual release request.

    OR and AND NOT are used so that all other digital-output bits remain
    unchanged.
*)
IF bReleaseRequest THEN

    io_udiDigitalOutputs :=
        io_udiDigitalOutputs OR C_UDI_BRAKE_RELEASE;

ELSE

    io_udiDigitalOutputs :=
        io_udiDigitalOutputs AND (NOT C_UDI_BRAKE_RELEASE);

END_IF


(*
    Confirm the command that is actually present in the PDO data.

    Both conditions must be true:

        - Output mask bit 0 is enabled.
        - Digital output bit 0 is set.
*)
o_bReleaseRequestActive :=
    ((io_udiDigitalOutputsMask AND C_UDI_BRAKE_RELEASE) <> 0)
    AND
    ((io_udiDigitalOutputs AND C_UDI_BRAKE_RELEASE) <> 0);


(*
    =====================================================================
    INITIALISE BRAKE STATUS OUTPUTS
    =====================================================================

    Outputs are reset every PLC cycle before decoding the status.

    This prevents an old TRUE state from remaining latched when the
    drive changes to another brake state.
*)
o_eBrakeStatus          := E_CMMT_BrakeStatus.Invalid;

o_bBrakeClosed          := FALSE;
o_bBrakeOpen            := FALSE;
o_bBrakeOpening         := FALSE;
o_bBrakeClosing         := FALSE;
o_bBrakeTransitioning   := FALSE;
o_bBrakeStatusValid     := FALSE;


(*
    =====================================================================
    DECODE 2150:05 — HOLDING BRAKE 1 STATUS
    =====================================================================

        Value 0:
            Brake closed/applied.

        Value 1:
            Brake open/released.

        Value 2:
            Brake opening.

        Value 3:
            Brake closing.

    The opening and closing states are transitional states.
*)
CASE i_udiBrakeStatusRaw OF

    0:
        (*
            Brake closed/applied.

            The drive reports that the brake-control sequence has reached
            the closed state.
        *)
        o_eBrakeStatus      := E_CMMT_BrakeStatus.Closed;
        o_bBrakeClosed      := TRUE;
        o_bBrakeStatusValid := TRUE;


    1:
        (*
            Brake open/released.

            The drive reports that the brake-control sequence has reached
            the open state.
        *)
        o_eBrakeStatus      := E_CMMT_BrakeStatus.Open;
        o_bBrakeOpen        := TRUE;
        o_bBrakeStatusValid := TRUE;


    2:
        (*
            Brake opening.

            The CMMT is currently executing the configured brake-opening
            sequence or brake-release delay.
        *)
        o_eBrakeStatus          := E_CMMT_BrakeStatus.Opening;
        o_bBrakeOpening         := TRUE;
        o_bBrakeTransitioning   := TRUE;
        o_bBrakeStatusValid     := TRUE;


    3:
        (*
            Brake closing.

            The CMMT is currently executing the configured brake-closing
            sequence or brake-application delay.
        *)
        o_eBrakeStatus          := E_CMMT_BrakeStatus.Closing;
        o_bBrakeClosing         := TRUE;
        o_bBrakeTransitioning   := TRUE;
        o_bBrakeStatusValid     := TRUE;


ELSE
    (*
        Unexpected or unsupported value.

        This can indicate:

            - Incorrect PDO mapping
            - Incorrect data type
            - Incorrect byte alignment
            - Firmware/object-version mismatch
            - Invalid data while EtherCAT is not operational
    *)
    o_eBrakeStatus      := E_CMMT_BrakeStatus.Invalid;
    o_bBrakeStatusValid := FALSE;

END_CASE]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>